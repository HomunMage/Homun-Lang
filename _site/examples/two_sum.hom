// ─── examples/two_sum.hom ───────────────────────────────────────
// Demonstrates: nested for, break => value, comparison
use std

two_sum := (nums: @[int], target: int) -> @[int] {
  for i in range(len(nums)) {
    for j in range(i + 1, len(nums)) {
      if (nums[i] + nums[j] == target) { => @[i, j] }
    }
  }
  @[]
}

main := () -> _ {
  nums := @[2, 7, 11, 15]
  result := two_sum(nums, 9)
  print("Two Sum: {:?}", result)
}
